    {
      "type": "action",
      "name": "Explode",
      "system": {
        "actionType": {
          "value": "free"
        },
        "description": {
          "value": "<p><strong>Trigger</strong> A creature enters a square with an invisible mine triggers it</p><hr /><p>This causes an explosion that deals @Damage[max(@actor.level - 2, 3)d6[fire],max(@actor.level - 2, 3)d6[piercing]] damage (@Check[reflex|basic:true|dc:@actor.system.attributes.classDC.value]) to the creature and every creature in a @Template[type:emanation|distance:5] from the mine’s square.</p><hr /><p><strong>Heightened (+1)</strong> The fire damage and piercing damage dealt by a mine each increase by 1d6.</p>",
          "gm": ""
        },
